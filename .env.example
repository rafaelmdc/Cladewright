# Copy to .env (gitignored) for the dev stack. `make dev` reads it via docker compose.

# ── Django ──────────────────────────────────────────────────────
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Database (the db container) ─────────────────────────────────
# settings.py uses these (POSTGRES_DB present -> Postgres engine). POSTGRES_HOST/PORT
# are injected by compose (host "db"); leave them unset here.
POSTGRES_DB=cladewright
POSTGRES_USER=cladewright
POSTGRES_PASSWORD=change_me

# ── Ports ───────────────────────────────────────────────────────
APP_PORT=8000          # gunicorn bind inside the web container
BACKEND_HOST_PORT=8000 # host port -> web (Vite proxies /api here)
DB_HOST_PORT=5432      # host port -> db (optional, for psql/DBeaver)

# ── Container names ─────────────────────────────────────────────
DB_CONTAINER_NAME=cladewright-db
WEB_CONTAINER_NAME=cladewright-web
